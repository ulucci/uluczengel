  m_Script: {fileID: 11500000, guid: 10b4f7ec81b397a4cb75004f15b0d751, type: 3}
  m_Name: DorisLetterGood
  m_EditorClassIdentifier: Assembly-CSharp::LetterData
  lines:
  - "Sana bunu s\xF6ylememem gerekiyor ama \xE7ok iyi bir insana benziyorsun\u2026 "
  - "Ben baban\u0131n gayri resmi e\u015Fiyim  "
  - "Gilbert\u2019a yani karde\u015Fine ilac\u0131 sa\u011Flayarak hayatta kalmas\u0131n\u0131
    sa\u011Flad\u0131n"
  - "Ne kadar te\u015Fekk\xFCr etsem az\u2026 "
  - "Ve buraya bo\u015Funa gelmedik Baban \xF6lmedi Zebercet "
  - " Patron baban\u0131 ka\xE7\u0131rd\u0131 ve babana o mektubu yazd\u0131rd\u0131  "
  - "Sadece sen burada o pis patrona daha fazla para kazand\u0131r diye  "
  - "Baban\u0131 \xF6lm\xFC\u015F gibi g\xF6sterip sana olmayan bir borcu \xF6detiyor."
